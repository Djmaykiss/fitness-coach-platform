# =============================================================================
# Coach Fitness — variables de entorno (copiar a `.env.local`, NO commitear)
# =============================================================================

# --- Supabase (credenciales del proyecto; requeridas solo en modo `supabase`) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Backend de datos ---------------------------------------------------------
# `local`   -> todo en localStorage (default; no requiere Supabase).
# `supabase`-> todos los repos migrables usan Supabase (requiere credenciales).
NEXT_PUBLIC_DATA_BACKEND=local

# Override por-repo: fuerza a `supabase` SOLO los repos listados (separados por
# comas), útil para migrar/probar de a uno sin cambiar el backend global.
# Claves válidas: auth, settings, discover, onboardingContent, exerciseLibrary,
# lead, client, progress, trainingProgram, nutritionPlan, coaching, crm,
# notifications, user, plans, storage, media, testimonials, transformations.
# Ejemplo: NEXT_PUBLIC_SUPABASE_REPOS=auth,settings
NEXT_PUBLIC_SUPABASE_REPOS=

# --- Contenido demo -----------------------------------------------------------
# `true`  -> siembra seeds demo (cuentas demo, contenido de ejemplo) para dev.
# ausente/`false` -> producción: la app arranca vacía (empty-states), sin demo.
NEXT_PUBLIC_DEMO_CONTENT=false
